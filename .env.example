# ---------------------------------------------------------------------------
# API server (artifacts/api-server)
# ---------------------------------------------------------------------------

# Postgres connection string (required).
DATABASE_URL=postgres://user:password@localhost:5432/kore

# Port the API listens on (required).
PORT=8080

# Shared secret protecting the API (required, >= 16 chars).
# The server refuses to start without it. Generate with: openssl rand -hex 32
# Clients send it as:  Authorization: Bearer <token>
# NOTE: this token also acts as a master "owner" key — keep it secret.
API_AUTH_TOKEN=

# JWT signing secret (recommended, >= 32 chars). If unset, it is derived from
# API_AUTH_TOKEN. Set it explicitly to control session/token rotation.
JWT_SECRET=

# Product verticals (personas) exposed in the Copilot. Comma-separated ids:
# claire (dental), shopify (e-commerce), garage, crm, saas. When empty, ALL are
# available. The generic "tams" assistant is always on. Example: claire,crm
ENABLED_PRODUCTS=

# Self-registration is CLOSED by default (only the very first account can be
# created to bootstrap the owner). Set to "true" only when opening the app to
# multiple users — and only after per-tenant data isolation is in place.
SELF_REGISTRATION_ENABLED=

# Password-reset tokens are never returned by the API by default (they are
# logged server-side). For a single-user setup without email, set to "true" to
# receive the reset token in the HTTP response (less secure — accept the risk).
RESET_TOKEN_IN_RESPONSE=

# Comma-separated allowlist of exact browser origins for CORS (optional).
# If unset, only same-origin requests are allowed.
# Example: https://app.example.com,https://kore.vercel.app
FRONTEND_URL=

# ---------------------------------------------------------------------------
# LLM / AI providers (all optional — features degrade gracefully if absent).
# The Copilot routes through a multi-provider gateway and falls back to the
# next configured provider on failure. All options below are FREE.
# ---------------------------------------------------------------------------

# Which provider the Copilot prefers: "auto" (default), "gemini", "groq",
# "openrouter" or "ollama". In "auto" mode the order is
# gemini → groq → openrouter → ollama, limited to providers configured below.
AI_PROVIDER=auto

# Google Gemini (free tier). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash).
GEMINI_MODEL=

# Groq cloud (free tier — runs Llama / Qwen very fast). Also powers audio
# transcription (Whisper). Get a key: https://console.groq.com/keys
GROQ_API_KEY=
# Optional chat model override (default: llama-3.3-70b-versatile).
GROQ_MODEL=

# OpenRouter — FREE cloud access to open models (DeepSeek R1, Qwen, Llama…)
# with NO server to run. Create a free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model id (default: deepseek/deepseek-r1:free). Other free options:
# qwen/qwen-2.5-72b-instruct:free, meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=
# Optional attribution URL sent to OpenRouter (your app/site).
OPENROUTER_SITE_URL=

# Ollama — run open models locally for free (Llama, Qwen, DeepSeek R1, etc.).
# Install from https://ollama.com, then `ollama pull llama3.2`. Set the base
# URL of your Ollama server to enable it (e.g. http://localhost:11434).
OLLAMA_BASE_URL=
# Model to use on the Ollama server (default: llama3.2). Examples:
# qwen2.5, deepseek-r1, llama3.1, mistral.
OLLAMA_MODEL=

# ---------------------------------------------------------------------------
# External integrations (all optional, feature-flagged — off by default).
# Restricted to owner/admin. Credentials are never returned to the client.
# ---------------------------------------------------------------------------

# GitHub — let the app read your repos/issues and create issues via the
# official REST API. Create a fine-grained or classic Personal Access Token
# at https://github.com/settings/tokens with `repo` (or `public_repo`) and
# `read:user` scopes. Leave empty to keep the integration disabled.
GITHUB_TOKEN=

# FFmpeg — free, account-less video/audio toolkit (the open alternative to
# CapCut). NO variable is required: the binary is installed in the deploy image
# (nixpacks) and the integration enables itself when present. These optional
# overrides only matter if ffmpeg/ffprobe live at a non-standard path.
FFMPEG_PATH=
FFPROBE_PATH=

# Base path the web app is served under. Use "/" for single-service mode
# (the API serves the web app on the same origin).
BASE_PATH=/

# ---------------------------------------------------------------------------
# Frontend (artifacts/kore)
# ---------------------------------------------------------------------------

# Only needed for SEPARATE deploys (web app hosted apart from the API).
# Leave EMPTY in single-service mode — the app then calls /api on the same
# origin (no CORS, no extra config).
VITE_API_URL=
