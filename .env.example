# ============================================
# TAMS — Variables d'environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs.
# Sur Railway : configurer ces variables dans le dashboard > Variables.
# ============================================

# === BASE DE DONNÉES (REQUIS) ===
# Railway fournit DATABASE_URL automatiquement avec le plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# === SESSION (REQUIS) ===
# Générer avec : openssl rand -base64 32
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32

# === IA (OPTIONNEL) ===
# Pour la génération de scripts vidéo/audio par IA
# Replit AI Gateway — fourni automatiquement sur Replit
AI_GATEWAY_URL=
REPLIT_AI_API_KEY=

# === SERVEUR ===
PORT=8080
NODE_ENV=production
