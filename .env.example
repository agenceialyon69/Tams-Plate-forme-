# TAMS — Variables d'environnement\n\n# Copier ce fichier en .env et remplir les valeurs.\n# Sur Railway : configurer dans le dashboard > Variables.\n\n# === BASE DE DONNÉES (REQUIS) ===\n# Railway fournit DATABASE_URL automatiquement avec le plugin PostgreSQL\nDATABASE_URL=postgresql://user:password@host:5432/database\n\n# === SESSION (REQUIS) ===\n# Générer avec : openssl rand -base64 32\nSESSION_SECRET=change-me-generate-with-openssl-rand-base64-32\n\n# === IA (OPTIONNEL) ===\n# Replit AI Gateway — fourni automatiquement sur Replit\nAI_GATEWAY_URL=\nREPLIT_AI_API_KEY=\n\n# === SERVEUR ===\nPORT=8080\nNODE_ENV=production\n\n# === FRONTEND (OPTIONNEL) ===\n# URL de l'API pour le frontend en dev local.\n# En production Railway, laisser vide (même origine).\nVITE_API_URL=\n