# TAMS — Variables d'environnement
#
# Copier ce fichier en .env et remplir les valeurs.
# Sur Railway : configurer dans le dashboard > Variables.

# === BASE DE DONNÉES (REQUIS) ===
# Railway fournit DATABASE_URL automatiquement avec le plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# === SESSION (REQUIS) ===
# Générer avec : openssl rand -base64 32
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32

# === SERVEUR ===
PORT=8080
NODE_ENV=production
# BASE_PATH : préfixe de l'app frontend (/ en production Railway, /tams/ sur Replit)
BASE_PATH=/

# === CORS (OPTIONNEL) ===
# Si le frontend est sur un domaine différent du backend :
#   ALLOWED_ORIGINS=https://monapp.railway.app,https://monautredomaine.com
# Si laissé vide : toutes les origines sont autorisées (reflect-origin).
ALLOWED_ORIGINS=
# Alternative : juste l'URL du frontend
FRONTEND_URL=

# === IA GRATUITE (AU MOINS UN REQUIS POUR LE CHAT) ===
# Ordre de priorité : AI_BASE_URL → Ollama → Groq → Gemini → OpenRouter

# Override explicite (Ollama distant, passerelle custom…)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Ollama local (ex: http://localhost:11434/v1) — 100% gratuit
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3

# Groq — quota gratuit, très rapide (https://console.groq.com)
GROQ_API_KEY=

# Gemini — quota gratuit (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenRouter — modèles :free uniquement (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# === RETRO-COMPAT Replit AI Gateway ===
AI_GATEWAY_URL=
REPLIT_AI_API_KEY=
