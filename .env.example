# ============================================
# TAMS Configuration - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# Variables marked (REQUIRED) must be set for the app to function
# Variables with defaults work without explicit configuration
# ============================================

# === DATABASE (REQUIRED) ===
# Railway provides DATABASE_URL automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# Alternative: individual PG variables (Railway also provides these)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=tams

# === AUTHENTICATION (REQUIRED) ===
# JWT secret for signing tokens - generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# Master token for owner/admin access - generate with: openssl rand -hex 16
# Used for: API auth fallback, Red Team endpoint, first-time setup
API_AUTH_TOKEN=your-master-token-here

# JWT session duration (default: 8h)
# SESSION_DURATION=8h

# === SUPABASE AUTH (REQUIRED for frontend) ===
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === AI PROVIDERS ===
# At least one AI provider is recommended for Copilot functionality
# In "auto" mode, providers are tried in order: gemini -> groq -> openrouter -> ollama

# Provider selection: auto, gemini, groq, openrouter, ollama
# AI_PROVIDER=auto

# --- Google Gemini (FREE tier, recommended) ---
# Get from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# --- Groq (FREE tier, fast inference) ---
# Get from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (FREE models: DeepSeek R1, Qwen) ---
# Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=deepseek/deepseek-r1:free
# OPENROUTER_SITE_URL=https://tams.app

# --- Ollama (LOCAL, self-hosted) ---
# Install: https://ollama.ai and run: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# === AUDIO / TRANSCRIPTION ===
# --- Self-hosted Whisper (FREE, recommended for privacy) ---
# Deploy: https://github.com/fedirz/faster-whisper-server
# WHISPER_BASE_URL=http://localhost:8000
# WHISPER_MODEL=Systran/faster-whisper-large-v3
# WHISPER_API_KEY= (optional, for auth)

# === VIDEO / FFMPEG ===
# FFmpeg is usually installed in the container (nixpacks.toml handles it)
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
# CAPTION_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf

# === IMAGE GENERATION ===
# Enable/disable image generation (default: true)
# ENABLE_IMAGE_GENERATION=true

# Provider: auto, pollinations (keyless), huggingface
# IMAGE_PROVIDER=auto

# --- HuggingFace (FREE token, higher quality) ---
# Get from: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- Pollinations (KEYLESS, always available) ---
# POLLINATIONS_MODEL=flux

# === WEB SEARCH ===
# Provider: auto, tavily, brave, searxng, duckduckgo
# DuckDuckGo is always available as keyless fallback
# WEB_SEARCH_PROVIDER=auto

# --- Tavily (FREE tier 1000 requests/month) ---
# Get from: https://tavily.com
# TAVILY_API_KEY=tvly-...

# --- Brave Search (FREE tier 2000 requests/month) ---
# Get from: https://brave.com/search/api
# BRAVE_API_KEY=...

# --- SearXNG (SELF-HOSTED) ---
# Deploy: https://github.com/searxng/searxng-docker
# SEARXNG_URL=http://localhost:8888

# === INTEGRATIONS ===
# --- GitHub (optional, for repo integration) ---
# Get from: https://github.com/settings/tokens (classic token, repo scope)
# GITHUB_TOKEN=ghp_...

# --- Nexus AI (optional integration) ---
# NEXUS_AI_URL=

# === SERVER CONFIGURATION ===
# PORT=8080
# NODE_ENV=production

# Frontend URL for CORS (comma-separated for multiple origins)
# FRONTEND_URL=https://your-app.railway.app

# Client build directory (default: ../kore/dist/public)
# CLIENT_DIR=

# === DEBUG / DEV ===
# Debug endpoint token (DO NOT use in production)
# DEBUG_TOKEN=

# Log level: debug, info, warn, error
# LOG_LEVEL=info

# === REGISTRATION ===
# Allow self-registration (default: false - first account becomes owner)
# SELF_REGISTRATION_ENABLED=false

# Return reset token in response (ONLY for testing)
# RESET_TOKEN_IN_RESPONSE=false

# === PRODUCT PERSONAS ===
# Comma-separated list of enabled products
# ENABLED_PRODUCTS=tams,shopify,garage
