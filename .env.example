# TAMS — Variables d'environnement
#
# IMPORTANT: SECURITY REQUIREMENTS
# - All users must authenticate (Supabase Auth)
# - Data is isolated per user (RLS policies)
# - CORS is restricted in production

# === SUPABASE (REQUIRED FOR AUTH) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === DATABASE ===
# Railway provides DATABASE_URL automatically with PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/database

# === SESSION ===
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32

# === SERVER ===
PORT=8080
NODE_ENV=production
BASE_PATH=/

# === CORS (IMPORTANT FOR SECURITY) ===
# Production: MUST be set explicitly
ALLOWED_ORIGINS=https://your-app.railway.app
# Or use single frontend URL:
FRONTEND_URL=https://your-app.railway.app

# === DEVELOPMENT RUNTIME (FAIL-CLOSED) ===
# Keep false in production. Runtime routes also require a valid Supabase Bearer JWT.
TAMS_DEV_RUNTIME_ENABLED=false

# === AI FREE PROVIDERS (AT LEAST ONE REQUIRED FOR CHAT) ===
# Order: AI_BASE_URL → Ollama → Groq → Gemini → OpenRouter

# Explicit override (Ollama remote, custom gateway)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Ollama local (http://localhost:11434/v1) — 100% free
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3

# Groq — free quota, very fast (https://console.groq.com)
GROQ_API_KEY=

# Gemini — free quota (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenRouter — :free models only (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
